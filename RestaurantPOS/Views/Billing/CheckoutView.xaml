<UserControl x:Class="RestaurantPOS.Views.Billing.CheckoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Style for Table Status Cards -->
        <Style x:Key="TableCardStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Height" Value="90"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" BorderThickness="2" BorderBrush="Transparent">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="🪑" FontSize="18" HorizontalAlignment="Center" Margin="0,2"/>
                                <TextBlock Grid.Row="1" Text="{Binding TableName}" FontWeight="Bold" FontSize="13" Foreground="#2C3E50" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" x:Name="statusText" Text="{Binding Status}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2"/>
                            </Grid>
                        </Border>
                        
                        <ControlTemplate.Triggers>
                            <!-- Color based on status -->
                            <DataTrigger Binding="{Binding Status}" Value="available">
                                <Setter TargetName="border" Property="Background" Value="#E8F8F5"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#2ECC71"/>
                                <Setter TargetName="statusText" Property="Text" Value="Trống (Available)"/>
                                <Setter TargetName="statusText" Property="Foreground" Value="#27AE60"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="occupied">
                                <Setter TargetName="border" Property="Background" Value="#FDEDEC"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E74C3C"/>
                                <Setter TargetName="statusText" Property="Text" Value="Đang ăn (Occupied)"/>
                                <Setter TargetName="statusText" Property="Foreground" Value="#C0392B"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="needs_cleaning">
                                <Setter TargetName="border" Property="Background" Value="#FEF9E7"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F1C40F"/>
                                <Setter TargetName="statusText" Property="Text" Value="Cần dọn dẹp"/>
                                <Setter TargetName="statusText" Property="Foreground" Value="#D4AC0D"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="reserved">
                                <Setter TargetName="border" Property="Background" Value="#EBF5FB"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#3498DB"/>
                                <Setter TargetName="statusText" Property="Text" Value="Đã đặt trước"/>
                                <Setter TargetName="statusText" Property="Foreground" Value="#2980B9"/>
                            </DataTrigger>
                            
                            <!-- Highlight Selected Table -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="BorderThickness" Value="4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F5F6FA" Margin="10">
        <Grid.ColumnDefinitions>
            <!-- Column 0: Table Directory -->
            <ColumnDefinition Width="270"/>
            <!-- Column 1: Order details -->
            <ColumnDefinition Width="1.3*"/>
            <!-- Column 2: Payment panel -->
            <ColumnDefinition Width="1.1*"/>
        </Grid.ColumnDefinitions>

        <!-- 1. LEFT COLUMN: TABLE DIRECTORY -->
        <Border Grid.Column="0" Background="White" Margin="0,0,10,0" CornerRadius="8" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="DANH SÁCH BÀN ĂN" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="Chọn bàn đang có khách để thanh toán" FontSize="11" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                    <Separator Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Scrollable Grid of Tables -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Tables}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource TableCardStyle}"
                                        Command="{Binding DataContext.LoadTablesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Click="TableCard_Click"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Load manual refresh -->
                <Button Grid.Row="2" Content="🔄 Làm mới danh sách bàn" Height="35" Margin="0,10,0,0" Background="#7F8C8D" Foreground="White" FontWeight="Bold" Command="{Binding LoadTablesCommand}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- 2. MIDDLE COLUMN: BILL DETAIL -->
        <Border Grid.Column="1" Background="White" Margin="0,0,10,0" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Table info & Customer lookup -->
                    <RowDefinition Height="*"/>    <!-- Items DataGrid -->
                    <RowDefinition Height="Auto"/> <!-- Warn / Info -->
                    <RowDefinition Height="Auto"/> <!-- Bill calculation -->
                </Grid.RowDefinitions>

                <!-- Header / Info -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Table Name Header -->
                    <Border Grid.Row="0" Background="#E8EAF6" Padding="10" CornerRadius="6" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding SelectedTable.TableName, TargetNullValue='CHƯA CHỌN BÀN'}" FontSize="18" FontWeight="Bold" Foreground="#3F51B5"/>
                                <TextBlock Text="{Binding ActiveSession.OpenedAt, StringFormat='Giờ vào: dd/MM/yyyy HH:mm', TargetNullValue='Vui lòng chọn bàn đang sử dụng...'}" FontSize="11" Foreground="#5C6BC0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#2ECC71" CornerRadius="12" Padding="8,4" VerticalAlignment="Center" Visibility="{Binding HasActiveSession, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Đang Hoạt Động" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Customer Lookup -->
                    <Grid Grid.Row="1" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" 
                                 Text="{Binding CustomerPhoneSearch, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="32" 
                                 VerticalContentAlignment="Center" 
                                 Padding="8,0" 
                                 FontSize="12"
                                 Tag="Tìm SĐT khách hàng tích điểm..."
                                 IsEnabled="{Binding HasActiveSession}">
                            <!-- Placeholder -->
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush AlignmentX="Left" Stretch="None">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text=" Tìm SĐT khách hàng thân thiết..." Foreground="#A0A5B5" FontSize="12" FontStyle="Italic" Padding="4,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="5,0,0,0">
                            <Button Content="🔍 Tìm" Width="60" Height="32" Background="#3F51B5" Foreground="White" FontWeight="Bold" Command="{Binding SearchCustomerCommand}" IsEnabled="{Binding HasActiveSession}">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="❌ Hủy" Width="55" Height="32" Margin="3,0,0,0" Background="#E74C3C" Foreground="White" FontWeight="Bold" Command="{Binding ClearCustomerCommand}" IsEnabled="{Binding HasSelectedCustomer}">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- DataGrid of order items -->
                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding SessionItems}" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          Background="#FAFAFA" 
                          BorderThickness="1"
                          BorderBrush="#E0E0E0"
                          RowHeight="32"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EAEAEA"
                          IsEnabled="{Binding HasActiveSession}">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F0F2F5"/>
                            <Setter Property="Foreground" Value="#374151"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên món" Binding="{Binding DishName}" Width="*"/>
                        <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="45">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding Price, StringFormat='{}{0:N0}'}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="0,0,5,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="T.Tiền" Binding="{Binding Subtotal, StringFormat='{}{0:N0}'}" Width="85">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,0,5,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Trạng thái" Binding="{Binding StatusText}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Warning Panel for Cooking/Pending items -->
                <Border Grid.Row="2" Background="#FFF9C4" BorderBrush="#FBC02D" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,10,0,0" Visibility="{Binding HasWarningPendingCooking, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding WarningMessage}" Foreground="#F57F17" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- Billing Summary Calculations -->
                <Border Grid.Row="3" Background="#F8F9FA" Margin="0,10,0,0" Padding="12" CornerRadius="6" BorderThickness="1" BorderBrush="#E9ECEF">
                    <StackPanel>
                        <!-- Member display if loaded -->
                        <Grid Visibility="{Binding HasSelectedCustomer, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="👤 Khách hàng: " FontWeight="Bold" Foreground="#3F51B5"/>
                                <TextBlock Text="{Binding SelectedCustomer.FullName}" FontWeight="Bold" Foreground="#2C3E50"/>
                                <Border Background="#FFC107" CornerRadius="4" Padding="4,1" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding SelectedCustomer.MembershipTier}" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedCustomer.LoyaltyPoints, StringFormat='Điểm tích lũy: {0}'}" FontSize="12" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,2">
                            <TextBlock Text="Cộng tiền món ăn (ready &amp; served):" Foreground="#5A6A85"/>
                            <TextBlock Text="{Binding Subtotal, StringFormat='{}{0:N0} đ'}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="#2C3E50" FontSize="14"/>
                        </Grid>

                        <Grid Margin="0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Chiết khấu thành viên:" Foreground="#5A6A85"/>
                                <TextBlock Text="{Binding DiscountPercent, StringFormat=' ({0}%)'}" Foreground="#E74C3C" FontWeight="SemiBold" Visibility="{Binding HasSelectedCustomer, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding DiscountAmount, StringFormat='-{0:N0} đ'}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="#E74C3C" FontSize="14"/>
                        </Grid>
                        
                        <Separator Margin="0,8"/>

                        <Grid Margin="0,2">
                            <TextBlock Text="TỔNG TIỀN PHẢI THANH TOÁN:" FontWeight="Bold" Foreground="#2C3E50" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N0} đ'}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="#D35400" FontSize="20"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 3. RIGHT COLUMN: PAYMENT AND RECEIPT -->
        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Title / Split payment header -->
                    <RowDefinition Height="Auto"/> <!-- Split input fields -->
                    <RowDefinition Height="*"/>    <!-- Receipt preview -->
                    <RowDefinition Height="Auto"/> <!-- Next status & Pay action -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="HÌNH THỨC THANH TOÁN (SPLIT)" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="Hỗ trợ trả bằng nhiều hình thức kết hợp" FontSize="11" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                    <Separator Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Input Split Fields -->
                <Grid Grid.Row="1" IsEnabled="{Binding HasActiveSession}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 0: Cash -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="💵 Tiền mặt:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2C3E50"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CashAmount, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:0.##}'}" Height="30" Margin="5,4" Padding="5,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" FontWeight="Bold" FontSize="13"/>
                    <Button Grid.Row="0" Grid.Column="2" Content="Trả hết" Width="55" Height="30" Margin="0,4" Background="#E2E8F0" Command="{Binding PayFullCashCommand}">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                    </Button>

                    <!-- Row 1: Card -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="💳 Quẹt thẻ:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2C3E50"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CardAmount, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:0.##}'}" Height="30" Margin="5,4" Padding="5,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" FontWeight="Bold" FontSize="13"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="Trả hết" Width="55" Height="30" Margin="0,4" Background="#E2E8F0" Command="{Binding PayFullCardCommand}">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                    </Button>

                    <!-- Row 2: Bank transfer -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="🏦 Chuyển khoản:" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#2C3E50"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding BankTransferAmount, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:0.##}'}" Height="30" Margin="5,4" Padding="5,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" FontWeight="Bold" FontSize="13"/>
                    <Button Grid.Row="2" Grid.Column="2" Content="Trả hết" Width="55" Height="30" Margin="0,4" Background="#E2E8F0" Command="{Binding PayFullTransferCommand}">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                    </Button>

                    <!-- Calculations Display -->
                    <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Background="#F1F3F5" CornerRadius="6" Padding="10" Margin="0,8,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Đã trả / Cần trả:" FontSize="10" Foreground="#6C757D"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding TotalPaid, StringFormat='{}{0:N0}'}" FontWeight="Bold" Foreground="#2B8A3E"/>
                                    <TextBlock Text=" / " Foreground="#6C757D"/>
                                    <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N0}'}" FontWeight="Bold" Foreground="#495057"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="Tiền thối / Còn thiếu:" FontSize="10" Foreground="#6C757D"/>
                                <ContentControl Content="{Binding}">
                                    <ContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <!-- If paid enough, show change -->
                                                <TextBlock x:Name="changeText" Text="{Binding ChangeAmount, StringFormat='Thối lại: {0:N0}đ'}" FontWeight="Bold" Foreground="#2F9E44" Visibility="Collapsed"/>
                                                <!-- If not paid enough, show missing -->
                                                <TextBlock x:Name="missingText" Text="{Binding RemainingBalance, StringFormat='Thiếu: {0:N0}đ'}" FontWeight="Bold" Foreground="#E03131" Visibility="Visible"/>
                                            </StackPanel>
                                            <DataTemplate.Triggers>
                                                <!-- Simplified trigger checking TotalPaid >= TotalAmount -->
                                                <DataTrigger Binding="{Binding RemainingBalance}" Value="0">
                                                    <Setter TargetName="changeText" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="missingText" Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ContentControl.ContentTemplate>
                                </ContentControl>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Receipt Preview Panel -->
                <Border Grid.Row="2" Background="#FFFDE7" BorderThickness="1" BorderBrush="#FFF9C4" CornerRadius="6" Padding="5" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="🧾 Bản xem trước hóa đơn" FontSize="11" Foreground="#F57F17" FontWeight="Bold" Margin="5,2"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding ReceiptPreview}" FontFamily="Consolas, Courier New" FontSize="11" LineHeight="14" Foreground="#3E2723" Margin="5"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Actions: Status of table & Pay -->
                <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
                    <Grid Margin="0,0,0,10" IsEnabled="{Binding HasActiveSession}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Trạng thái bàn sau thanh toán:" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="#495057"/>
                        <ComboBox Grid.Column="1" 
                                  ItemsSource="{Binding TableStatuses}" 
                                  SelectedItem="{Binding SelectedNextTableStatus}" 
                                  Width="130" 
                                  Height="28" 
                                  VerticalContentAlignment="Center" 
                                  Margin="5,0,0,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock x:Name="itemText" Text="{Binding}"/>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="needs_cleaning">
                                            <Setter TargetName="itemText" Property="Text" Value="🧹 Cần dọn dẹp"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding}" Value="available">
                                            <Setter TargetName="itemText" Property="Text" Value="✅ Trống sẵn sàng"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" Content="🧹 Clear" Height="40" Margin="0,0,5,0" Background="#CED4DA" Foreground="#495057" FontWeight="Bold" Command="{Binding ClearPaymentCommand}" IsEnabled="{Binding HasActiveSession}">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                        </Button>
                        
                        <Button Grid.Column="1" Content="💰 THANH TOÁN (PAY)" Height="40" Background="#3F51B5" Foreground="White" FontWeight="Bold" FontSize="14" Command="{Binding CheckoutCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                    <!-- Status Display -->
                    <Border CornerRadius="4" Background="#E8F8F5" Margin="0,8,0,0" Padding="8,4" Visibility="{Binding StatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center" FontWeight="Bold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding StatusColor}"/>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
