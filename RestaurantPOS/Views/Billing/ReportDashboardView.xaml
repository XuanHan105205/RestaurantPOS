<UserControl x:Class="RestaurantPOS.Views.Billing.ReportDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Background="#F5F6FA" Margin="10">
        <Grid.RowDefinitions>
            <!-- Row 0: KPI Cards -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Filter bar -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: Charts and Tables -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. KPI SUMMARY CARDS -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Total Revenue -->
            <Border Grid.Column="0" Background="White" Margin="0,0,8,0" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E6ED">
                <StackPanel>
                    <TextBlock Text="💰 TỔNG DOANH THU" FontSize="11" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <TextBlock Text="{Binding TotalRevenue, StringFormat='{}{0:N0} đ'}" FontSize="20" FontWeight="Bold" Foreground="#2ECC71" Margin="0,8,0,0"/>
                    <TextBlock Text="Doanh thu thực nhận sau giảm giá" FontSize="10" Foreground="#BDC3C7" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 2: Total Invoices -->
            <Border Grid.Column="1" Background="White" Margin="0,0,8,0" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E6ED">
                <StackPanel>
                    <TextBlock Text="🧾 TỔNG HÓA ĐƠN" FontSize="11" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <TextBlock Text="{Binding TotalInvoices, StringFormat='{}{0:N0}'}" FontSize="20" FontWeight="Bold" Foreground="#3498DB" Margin="0,8,0,0"/>
                    <TextBlock Text="Số lượt bàn đã checkout thành công" FontSize="10" Foreground="#BDC3C7" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 3: Total Discount -->
            <Border Grid.Column="2" Background="White" Margin="0,0,8,0" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E6ED">
                <StackPanel>
                    <TextBlock Text="📉 TỔNG CHIẾT KHẤU" FontSize="11" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <TextBlock Text="{Binding TotalDiscount, StringFormat='{}{0:N0} đ'}" FontSize="20" FontWeight="Bold" Foreground="#E74C3C" Margin="0,8,0,0"/>
                    <TextBlock Text="Giá trị giảm giá cho thành viên VIP" FontSize="10" Foreground="#BDC3C7" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 4: Avg Order Value -->
            <Border Grid.Column="3" Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E6ED">
                <StackPanel>
                    <TextBlock Text="📊 HÓA ĐƠN TRUNG BÌNH" FontSize="11" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <TextBlock Text="{Binding AverageOrderValue, StringFormat='{}{0:N0} đ'}" FontSize="20" FontWeight="Bold" Foreground="#9B59B6" Margin="0,8,0,0"/>
                    <TextBlock Text="Doanh thu trung bình trên mỗi bàn" FontSize="10" Foreground="#BDC3C7" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 2. FILTER BAR -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,12" BorderThickness="1" BorderBrush="#E0E6ED">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Từ ngày:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding StartDate}" Width="130" Height="28" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Column="2" Text="Đến ngày:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2C3E50" Margin="15,0,8,0"/>
                <DatePicker Grid.Column="3" SelectedDate="{Binding EndDate}" Width="130" Height="28" VerticalContentAlignment="Center"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <Button Content="Hôm nay" Command="{Binding FilterTodayCommand}" Height="28" Padding="10,0" Margin="0,0,5,0" Background="#ECEFF1" Foreground="#374151" BorderThickness="0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                    </Button>
                    <Button Content="7 ngày qua" Command="{Binding FilterLast7DaysCommand}" Height="28" Padding="10,0" Margin="0,0,5,0" Background="#ECEFF1" Foreground="#374151" BorderThickness="0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                    </Button>
                    <Button Content="Tháng này" Command="{Binding FilterThisMonthCommand}" Height="28" Padding="10,0" Background="#ECEFF1" Foreground="#374151" BorderThickness="0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                    </Button>
                </StackPanel>

                <Button Grid.Column="5" Content="🔍 Tải dữ liệu" Command="{Binding LoadReportCommand}" Width="110" Height="30" Background="#3F51B5" Foreground="White" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- 3. DETAILED CHARTS AND DATA -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <!-- Chart panel -->
                <ColumnDefinition Width="1.3*"/>
                <!-- Table summary panel -->
            </Grid.ColumnDefinitions>

            <!-- Column 0: Visual Chart Panels -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.1*"/>
                    <!-- Top Dishes chart -->
                    <RowDefinition Height="*"/>
                    <!-- Payment Methods chart -->
                </Grid.RowDefinitions>

                <!-- Panel A: Top Dishes -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderThickness="1" BorderBrush="#E0E6ED">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="🔥 TOP MÓN ĂN BÁN CHẠY" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TopDishes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Labels -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding DishName}" FontWeight="SemiBold" Foreground="#34495E" FontSize="12"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat='{}{0} suất'}" Foreground="#7F8C8D" FontSize="11" FontWeight="Bold"/>
                                            </Grid>
                                            
                                            <!-- Progress bar styled as bar chart -->
                                            <ProgressBar Grid.Row="1" Value="{Binding Percentage}" Height="12" Foreground="#3F51B5" Background="#ECEFF1" BorderThickness="0" Margin="0,4,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Panel B: Payment Method Breakdown -->
                <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E6ED">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="💳 PHƯƠNG THỨC THANH TOÁN" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                        
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding PaymentMethods}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Labels -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding MethodText}" FontWeight="SemiBold" Foreground="#34495E" FontSize="12"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N0} đ'}" FontWeight="Bold" Foreground="#2C3E50" FontSize="12"/>
                                                <TextBlock Text="{Binding TransactionCount, StringFormat=' ({0} gd)'}" Foreground="#7F8C8D" FontSize="10" VerticalAlignment="Bottom"/>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <!-- Progress bar chart -->
                                        <ProgressBar Grid.Row="1" Value="{Binding Percentage}" Height="12" Foreground="#2ECC71" Background="#ECEFF1" BorderThickness="0" Margin="0,4,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- Column 1: Detailed Sales Summary List -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E6ED">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="📊 BẢNG DOANH THU HÀNG NGÀY" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding DailySales}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              Background="#FAFAFA" 
                              BorderThickness="1"
                              BorderBrush="#E0E0E0"
                              RowHeight="35"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EAEAEA">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F0F2F5"/>
                                <Setter Property="Foreground" Value="#374151"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="8,5"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#D1D5DB"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ngày" Binding="{Binding SaleDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="110"/>
                            <DataGridTextColumn Header="Số HĐ" Binding="{Binding TotalInvoices}" Width="65">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Tổng tiền món" Binding="{Binding TotalSubtotal, StringFormat='{}{0:N0}'}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,5,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Tổng giảm giá" Binding="{Binding TotalDiscount, StringFormat='{}{0:N0}'}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                        <Setter Property="Padding" Value="0,0,5,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Thực nhận" Binding="{Binding TotalRevenue, StringFormat='{}{0:N0}'}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#2ECC71"/>
                                        <Setter Property="Padding" Value="0,0,5,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
