<UserControl x:Class="RestaurantPOS.Views.Inventory.RecipeMappingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="#F5F6FA">
        <Grid.ColumnDefinitions>
            <!-- Cột trái: Chọn Món ăn -->
            <ColumnDefinition Width="220"/>
            <!-- Cột giữa: Công thức nguyên liệu -->
            <ColumnDefinition Width="1.4*"/>
            <!-- Cột phải: Form gán định lượng -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 1. CỘT TRÁI: DANH SÁCH MÓN ĂN -->
        <Border Grid.Column="0" Background="White" Margin="0,0,10,0" CornerRadius="8" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="THỰC ĐƠN MÓN ĂN" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="Chọn món ăn để lập công thức" FontSize="11" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                    <Separator Margin="0,8,0,0"/>
                </StackPanel>

                <!-- ListBox chọn món ăn -->
                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding Dishes}" 
                         SelectedItem="{Binding SelectedDish}"
                         DisplayMemberPath="DishName"
                         BorderThickness="1"
                         BorderBrush="#E2E8F0"
                         Background="#FAFAFA"
                         FontSize="12"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>

        <!-- 2. CỘT GIỮA: CÔNG THỨC ĐỊNH LƯỢNG MÓN ĂN -->
        <Border Grid.Column="1" Background="White" Margin="0,0,10,0" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <Border Background="#E8EAF6" Padding="8" CornerRadius="6" Margin="0,0,0,5">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedDish.DishName, TargetNullValue='VUI LÒNG CHỌN MÓN ĂN'}" FontSize="15" FontWeight="Bold" Foreground="#3F51B5"/>
                            <TextBlock Text="Danh sách nguyên liệu hao phí cho 1 suất ăn" FontSize="11" Foreground="#5C6BC0"/>
                        </StackPanel>
                    </Border>
                    <Separator Margin="0,5,0,0"/>
                </StackPanel>

                <!-- DataGrid hiển thị công thức của món ăn đang chọn -->
                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding RecipeItems}" 
                          SelectedItem="{Binding SelectedRecipeItem}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          Background="#FAFAFA" 
                          BorderThickness="1"
                          BorderBrush="#E0E0E0"
                          RowHeight="32"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EAEAEA"
                          IsEnabled="{Binding IsDishSelected}">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F0F2F5"/>
                            <Setter Property="Foreground" Value="#374151"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên nguyên liệu" Binding="{Binding IngredientName}" Width="*"/>
                        <DataGridTextColumn Header="Định lượng hao phí" Binding="{Binding QuantityPerServing, StringFormat='{}{0:0.####}'}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="0,0,5,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Đơn vị tính" Binding="{Binding Unit}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 3. CỘT PHẢI: FORM GÁN ĐỊNH LƯỢNG MỚI -->
        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="ĐỊNH LƯỢNG NGUYÊN LIỆU" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="Thêm/sửa nguyên liệu cấu thành món" FontSize="11" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                    <Separator Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Input fields -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" IsEnabled="{Binding IsDishSelected}">
                    <StackPanel Margin="0,5">
                        <!-- Chọn nguyên liệu -->
                        <TextBlock Text="Chọn nguyên liệu *" Foreground="#34495E" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Ingredients}" 
                                  SelectedItem="{Binding SelectedIngredient}" 
                                  DisplayMemberPath="IngredientName" 
                                  Height="35" 
                                  VerticalContentAlignment="Center" 
                                  Margin="0,0,0,15"/>

                        <!-- Định lượng hao phí -->
                        <TextBlock Text="Định lượng cho 1 phần ăn *" Foreground="#34495E" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding QuantityPerServing, UpdateSourceTrigger=PropertyChanged}" Height="35" VerticalContentAlignment="Center" Padding="8,0" FontSize="13" Margin="0,0,0,5"/>
                        <TextBlock Text="Ví dụ: 0.15 (tương đương 150g nếu ĐVT là kg)" FontSize="10" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,0,0,15"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Action buttons -->
                <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Nút Xóa (nếu đang chọn dòng) -->
                        <Button Grid.Column="0" Content="🗑️ Xóa" Height="38" Background="#E74C3C" Foreground="White" FontWeight="Bold" Margin="0,0,5,0" Command="{Binding DeleteRecipeItemCommand}" Visibility="{Binding IsRecipeItemSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                        </Button>

                        <!-- Nút Hủy chọn -->
                        <Button Grid.Column="0" Content="❌ Hủy" Height="38" Background="#CED4DA" Foreground="#495057" FontWeight="Bold" Margin="0,0,5,0" Command="{Binding ClearFormCommand}" Visibility="{Binding IsRecipeItemSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <!-- Nút Lưu -->
                        <Button Grid.Column="1" Grid.ColumnSpan="2" Content="💾 CẬP NHẬT CÔNG THỨC" Height="38" Background="#3F51B5" Foreground="White" FontWeight="Bold" FontSize="13" Command="{Binding SaveRecipeItemCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                    <!-- Status Display -->
                    <Border CornerRadius="4" Margin="0,10,0,0" Padding="8,4" Visibility="{Binding StatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F8F9FA"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusColor}" Value="#2ECC71">
                                        <Setter Property="Background" Value="#E8F8F5"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusColor}" Value="#E74C3C">
                                        <Setter Property="Background" Value="#FDEDEC"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center" FontWeight="Bold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding StatusColor}"/>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
