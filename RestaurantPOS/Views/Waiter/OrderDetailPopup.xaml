<Window x:Class="RestaurantPOS.Views.Waiter.OrderDetailPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestaurantPOS.Views.Waiter"
        mc:Ignorable="d"
        Title="{Binding TableName, StringFormat='Chi tiết gọi món - {0}'}" 
        Height="550" Width="750"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8F9FA">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Style for action buttons (+ and -) -->
        <Style x:Key="QuantityButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background" Value="#EDF2F7"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderBrush="#CBD5E0" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CBD5E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title & Info -->
            <RowDefinition Height="*"/>    <!-- Order Items Grid -->
            <RowDefinition Height="Auto"/> <!-- Summary Area -->
            <RowDefinition Height="Auto"/> <!-- Close Button -->
        </Grid.RowDefinitions>

        <!-- TITLE & INFO -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding TableName, StringFormat='📋 CHI TIẾT MÓN ĐÃ GỌI - {0}'}" FontSize="18" FontWeight="Bold" Foreground="#1A365D"/>
                <TextBlock Text="{Binding ActiveSession.SessionId, StringFormat='Mã Session ăn uống: # {0}'}" FontSize="12" Foreground="#718096" Margin="0,3,0,0"/>
            </StackPanel>
            
            <Border Background="#E2E8F0" Height="1" VerticalAlignment="Bottom"/>
        </Grid>

        <!-- ORDER ITEMS LIST -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <ListBox ItemsSource="{Binding OrderedItems}" 
                     SelectedItem="{Binding SelectedItem}"
                     Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Padding="5">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#EDF2F7" BorderThickness="0,0,0,1" Padding="10" Margin="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- 1. Tên món và giá -->
                                    <ColumnDefinition Width="220"/>
                                    <!-- 2. Số lượng và nút tăng giảm -->
                                    <ColumnDefinition Width="110"/>
                                    <!-- 3. Thành tiền -->
                                    <ColumnDefinition Width="100"/>
                                    <!-- 4. Ghi chú -->
                                    <ColumnDefinition Width="*"/>
                                    <!-- 5. Trạng thái và Hủy món -->
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>

                                <!-- Column 1: Dish name and unit price -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DishName}" FontSize="13" FontWeight="Bold" Foreground="#2D3748" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Price, StringFormat='{}{0:N0} đ'}" FontSize="11" Foreground="#718096" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Column 2: Quantity buttons (only enabled if pending) -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Content="-" Style="{StaticResource QuantityButtonStyle}" 
                                            Command="{Binding DataContext.DecrementCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding IsPending}"/>
                                    
                                    <TextBlock Text="{Binding Quantity}" FontSize="13" FontWeight="Bold" Width="25" TextAlignment="Center" VerticalAlignment="Center"/>
                                    
                                    <Button Content="+" Style="{StaticResource QuantityButtonStyle}"
                                            Command="{Binding DataContext.IncrementCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding IsPending}"/>
                                </StackPanel>

                                <!-- Column 3: Subtotal -->
                                <TextBlock Grid.Column="2" Text="{Binding Subtotal, StringFormat='{}{0:N0} đ'}" FontSize="13" FontWeight="Bold" Foreground="#319795" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>

                                <!-- Column 4: Notes (editable if pending, otherwise read-only) -->
                                <Grid Grid.Column="3" Margin="5,0" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" 
                                             IsEnabled="{Binding IsPending}" 
                                             Padding="5,3" FontSize="11" VerticalContentAlignment="Center" BorderBrush="#E2E8F0"/>
                                    <Button Grid.Column="1" Content="Lưu" 
                                            Command="{Binding DataContext.SaveNoteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}"
                                            Background="#4A5568" Foreground="White" Width="32" Margin="3,0,0,0" FontSize="10" FontWeight="SemiBold" Height="22" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- Column 5: Status text and Cancel button -->
                                <Grid Grid.Column="4" VerticalAlignment="Center" Margin="5,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Status indicator -->
                                    <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="pending">
                                                        <Setter Property="Foreground" Value="#D69E2E"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="cooking">
                                                        <Setter Property="Foreground" Value="#3182CE"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="ready">
                                                        <Setter Property="Foreground" Value="#38A169"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="served">
                                                        <Setter Property="Foreground" Value="#2B6CB0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="cancelled">
                                                        <Setter Property="Foreground" Value="#E53E3E"/>
                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Cancel button (only shown if pending) -->
                                    <Button Grid.Column="1" Content="🗑️" 
                                            Command="{Binding DataContext.CancelItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}"
                                            Background="Transparent" BorderThickness="0" Margin="5,0,0,0" Cursor="Hand" ToolTip="Hủy món này"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- SUMMARY AREA -->
        <Border Grid.Row="2" Background="#EDF2F7" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Tổng cộng tiền món ăn hiện tại (Chưa bao gồm giảm giá/VAT):" FontSize="12" Foreground="#4A5568" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="{Binding SessionTotal, StringFormat='{}{0:N0} đ'}" FontSize="18" FontWeight="ExtraBold" Foreground="#2C5282" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- CLOSE BUTTON -->
        <Button Grid.Row="3" Content="ĐÓNG HỘP THOẠI" Click="Close_Click"
                Background="#4A5568" Foreground="White" Height="40" FontSize="13" FontWeight="Bold" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
