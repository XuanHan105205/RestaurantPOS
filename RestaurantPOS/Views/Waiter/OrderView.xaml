<UserControl x:Class="RestaurantPOS.Views.Waiter.OrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.Views.Waiter"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="#F8F9FA">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Style for Category ListBoxItem (looks like clean sidebar buttons) -->
        <Style x:Key="CategoryItemStyle" TargetType="ListBoxItem">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" Padding="15,0" CornerRadius="8" Background="Transparent" SnapsToDevicePixels="True">
                            <TextBlock x:Name="Text" Text="{Binding CategoryName}" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#4A5568"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#EDF2F7"/>
                                <Setter TargetName="Text" Property="Foreground" Value="#2D3748"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3182CE"/>
                                <Setter TargetName="Text" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Dish Card ListBoxItem -->
        <Style x:Key="DishItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" 
                                CornerRadius="12" 
                                BorderThickness="1" 
                                Background="White"
                                BorderBrush="#E2E8F0"
                                Width="180"
                                Height="160"
                                Padding="12"
                                Cursor="Hand">
                            <Border.Effect>
                                <DropShadowEffect Color="#A0AEC0" BlurRadius="4" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>       <!-- Dish Name -->
                                    <RowDefinition Height="Auto"/>    <!-- Price -->
                                    <RowDefinition Height="Auto"/>    <!-- Action Add -->
                                </Grid.RowDefinitions>

                                <!-- Name -->
                                <TextBlock Grid.Row="0" Text="{Binding DishName}" FontSize="14" FontWeight="Bold" Foreground="#2D3748" TextWrapping="Wrap" VerticalAlignment="Top"/>

                                <!-- Price -->
                                <TextBlock Grid.Row="1" Text="{Binding Price, StringFormat='{}{0:N0} đ'}" FontSize="15" FontWeight="ExtraBold" Foreground="#319795" Margin="0,5,0,5"/>

                                <!-- Quick Add button -->
                                <Button Grid.Row="2" Content="➕ Thêm món" 
                                        Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="#EBF8FF" Foreground="#2B6CB0" Height="30" FontSize="12" FontWeight="Bold" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#BEE3F8" BorderThickness="1">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3182CE"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#CBD5E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <!-- 1. Danh mục menu (Trái) -->
            <ColumnDefinition Width="200"/>
            <!-- 2. Menu món ăn (Giữa) -->
            <ColumnDefinition Width="*"/>
            <!-- 3. Giỏ hàng món ăn hiện tại (Phải) -->
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- 1. CỘT DANH MỤC (TRÁI) -->
        <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📂 DANH MỤC" FontSize="15" FontWeight="Bold" Foreground="#2D3748" Margin="5,5,5,15"/>

                <ListBox Grid.Row="1" ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         ItemContainerStyle="{StaticResource CategoryItemStyle}"
                         Background="Transparent" BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- 2. CỘT THỰC ĐƠN MÓN ĂN (GIỮA) -->
        <Grid Grid.Column="1" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Thanh tìm kiếm & Header -->
                <RowDefinition Height="*"/>    <!-- Grid món ăn -->
            </Grid.RowDefinitions>

            <!-- Header & Search -->
            <Grid Grid.Row="0" Margin="5,0,5,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <TextBlock Text="📖 THỰC ĐƠN GỌI MÓN" FontSize="18" FontWeight="Bold" Foreground="#2D3748"/>
                    <TextBlock Text="{Binding SelectedTable.TableName, StringFormat='Chọn món ăn cho {0}'}" FontSize="12" Foreground="#718096"/>
                </StackPanel>

                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="10,5" FontSize="13" VerticalContentAlignment="Center" BorderBrush="#CBD5E0" Height="36"
                         Tag="Tìm kiếm món ăn..." Name="TxtSearch"/>
            </Grid>

            <!-- Danh sách món ăn -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ListBox ItemsSource="{Binding FilteredDishes}"
                         ItemContainerStyle="{StaticResource DishItemStyle}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </ScrollViewer>
        </Grid>

        <!-- 3. GIỎ HÀNG THỜI ĐIỂM HIỆN TẠI (PHẢI) -->
        <Border Grid.Column="2" Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#A0AEC0" BlurRadius="10" ShadowDepth="4" Opacity="0.1"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Title giỏ hàng -->
                    <RowDefinition Height="*"/>    <!-- List các món trong giỏ -->
                    <RowDefinition Height="Auto"/> <!-- Gợi ý AI -->
                    <RowDefinition Height="Auto"/> <!-- Tổng cộng -->
                    <RowDefinition Height="Auto"/> <!-- Button Actions -->
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <Grid>
                        <TextBlock Text="🛒 ĐƠN GỌI MÓN" FontSize="16" FontWeight="Bold" Foreground="#1A365D"/>
                        <TextBlock Text="{Binding SelectedTable.TableName}" FontSize="14" FontWeight="Bold" Foreground="#3182CE" HorizontalAlignment="Right"/>
                    </Grid>
                    <Separator Margin="0,10,0,0"/>
                </StackPanel>

                <!-- List Items -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <!-- Giỏ trống -->
                    <TextBlock Text="Chưa chọn món nào." FontSize="14" Foreground="#A0AEC0" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding IsCartEmpty, Converter={StaticResource BoolToVis}}"/>

                    <!-- Giỏ có hàng -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsCartNotEmpty, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding Cart}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EDF2F7" BorderThickness="0,0,0,1" Padding="0,10" Margin="0,0,0,5">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Tên món và giá -->
                                            <Grid Grid.Row="0">
                                                <TextBlock Text="{Binding Dish.DishName}" FontSize="13" FontWeight="Bold" Foreground="#2D3748" Width="180" HorizontalAlignment="Left" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Subtotal, StringFormat='{}{0:N0} đ'}" FontSize="13" FontWeight="SemiBold" Foreground="#4A5568" HorizontalAlignment="Right"/>
                                            </Grid>

                                            <!-- Note -->
                                            <TextBox Grid.Row="1" Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" 
                                                     Padding="6,3" Margin="0,6,0,6" FontSize="11" Foreground="#4A5568" BorderBrush="#E2E8F0"
                                                     Tag="Ghi chú món ăn... (ví dụ: Không hành, cay vừa)"/>

                                            <!-- Chỉnh số lượng -->
                                            <Grid Grid.Row="2">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                    <Button Content="-" Command="{Binding DataContext.DecrementCartQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                                                            Width="24" Height="24" FontSize="12" FontWeight="Bold" Background="#EDF2F7" Foreground="#4A5568" Cursor="Hand">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    
                                                    <TextBlock Text="{Binding Quantity}" FontSize="13" FontWeight="Bold" Foreground="#2D3748" VerticalAlignment="Center" Margin="10,0,10,0"/>

                                                    <Button Content="+" Command="{Binding DataContext.IncrementCartQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                                                            Width="24" Height="24" FontSize="12" FontWeight="Bold" Background="#EDF2F7" Foreground="#4A5568" Cursor="Hand">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>

                                                <Button Content="🗑️" Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                                                        Foreground="#E53E3E" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Gợi ý AI -->
                <StackPanel Grid.Row="2" Margin="0,0,0,15">
                    <TextBlock Text="💡 AI GỢI Ý MÓN KÈM THEO" FontSize="12" FontWeight="Bold" Foreground="#319795" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding RecommendedDishes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E2E8F0" BorderThickness="1" Background="#F8FAFC" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DishName}" FontSize="12" FontWeight="Bold" Foreground="#2D3748" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Price, StringFormat='{}{0:N0} đ'}" FontSize="11" FontWeight="SemiBold" Foreground="#319795" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="➕ Thêm" 
                                                Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="#EBF8FF" Foreground="#2B6CB0" Height="28" Padding="8,0" FontSize="11" FontWeight="Bold" Cursor="Hand" VerticalAlignment="Center">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderBrush="#BEE3F8" BorderThickness="1">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Tổng cộng -->
                <Border Grid.Row="3" Background="#F7FAFC" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <TextBlock Text="Tổng tạm tính:" FontSize="14" FontWeight="Bold" Foreground="#4A5568" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CartTotal, StringFormat='{}{0:N0} đ'}" FontSize="18" FontWeight="ExtraBold" Foreground="#2B6CB0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Actions -->
                <StackPanel Grid.Row="4">
                    <Button Content="✔️ XÁC NHẬN GỌI MÓN" Command="{Binding ConfirmOrderCommand}"
                            Background="#319795" Foreground="White" Height="45" FontSize="14" FontWeight="Bold" Margin="0,0,0,8" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="🔙 QUAY LẠI SƠ ĐỒ BÀN" Command="{Binding CancelOrderCommand}"
                            Background="#718096" Foreground="White" Height="38" FontSize="12" FontWeight="Bold" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
